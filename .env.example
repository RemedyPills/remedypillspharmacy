# =============================
# Remedy Pills Pharmacy - ENV
# =============================
# Server
NODE_ENV=production
PORT=5000
APP_BASE_URL=https://your-domain.example  # no trailing slash
SESSION_SECRET=change-me-to-a-long-random-string

# Database (Postgres)
DATABASE_URL=postgres://user:password@host:5432/dbname

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth - Facebook
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Email (optional - for sending emails)
GMAIL_APP_PASSWORD=

# Twilio (optional - for SMS)
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY=
TWILIO_API_KEY_SECRET=
TWILIO_FROM_NUMBER=

# OpenAI (optional - for food analysis)
OPENAI_API_KEY=
# OPENAI_BASE_URL=
